{
  "name": "backend",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "retry-pending-registrations": "node scripts/retry_pending_registrations.js",
    "build": "npm install",
    "test": "npx jest --config jest.config.cjs",
    "test:utils": "npx jest --config jest.config.cjs tests/email.test.js tests/strings.test.js tests/security_utils.test.js",
    "test:services": "npx jest --config jest.config.cjs tests/user_service.test.js",
    "test:models": "npx jest --config jest.config.cjs tests/user_model.test.js",
    "test:middleware": "npx jest --config jest.config.cjs tests/auth_middleware.test.js",
    "test:controllers": "npx jest --config jest.config.cjs tests/user_controller.test.js",
    "test:mailer": "npx jest --config jest.config.cjs tests/mailer.test.js",
    "test:security": "npx jest --config jest.config.cjs tests/security.test.js",
    "test:integration": "npx jest --config jest.config.cjs tests/integration.test.js",
    "test:socket": "npx jest --config jest.config.cjs tests/socket.test.js",
    "test:coverage": "npx jest --config jest.config.cjs --coverage",
    "test:all": "npm run test:utils && npm run test:services && npm run test:models && npm run test:middleware && npm run test:controllers && npm run test:mailer && npm run test:security && npm run test:socket"
  },
  "dependencies": {
    "@google/generative-ai": "0.21.0",
    "axios": "^1.15.0",
    "bcryptjs": "3.0.3",
    "cookie": "^1.1.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "csurf": "^1.2.2",
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "express-rate-limit": "^8.2.2",
    "express-validator": "7.3.2",
    "ioredis": "5.10.1",
    "jsonwebtoken": "9.0.3",
    "mongodb": "7.1.1",
    "mongoose": "^9.4.1",
    "morgan": "1.10.1",
    "nodemailer": "^8.0.5",
    "nodemon": "3.1.14",
    "path-to-regexp": "^8.4.2",
    "socket.io": "4.8.3",
    "validator": "^13.15.23"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "babel-jest": "^30.3.0",
    "jest": "^30.2.0",
    "rimraf": "^6.1.3",
    "socket.io-client": "4.8.1",
    "supertest": "^7.2.2"
  }
}
